# Oakshade Admin — environment variables
# Copy to .env and fill in. Never commit .env.

# Admin basic-auth credentials (required when HOST is non-localhost or REQUIRE_AUTH=1)
# ADMIN_USER=admin
# ADMIN_PASS=

# Redis (used by the chick-bot followup queue)
# REDIS_URL=redis://localhost:6379

# Contact form delivery (TODO: fill in)
# CONTACT_TO=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=                 # Gmail App Password, not the login password
