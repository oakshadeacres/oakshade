---
import '../styles/global.css';
import site from '../content/site.json';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  ogImage?: string;
}

const {
  title = 'Oakshade Acres – English Orpingtons & Specialty Chicks | Dayton, TX',
  description = 'Quality day-old chicks and hatching eggs in Dayton, Texas. Specializing in English Orpingtons (Lavender, Chocolate, Jubilee, Gold/Silver Laced), Polish, and Bantam Cochins & Easter Eggers. Small-farm quality, hand-raised with care.',
  path = '/',
  ogImage = '/images/site/og.png',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteOrigin = Astro.site?.origin ?? 'https://oakshadeorpingtons.com';
const pathWithSlash = path === '/' ? '/' : (path.startsWith('/') ? path : `/${path}`);
const canonical = `${siteOrigin}${base}${pathWithSlash}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteOrigin}${base}${ogImage}`;

const phoneHref = site.footer.getInTouch.items.find((i) => i.href.startsWith('tel:'))?.href ?? '';
const phone = phoneHref.replace('tel:', '') || '+19363671974';
const email = site.contact.email;
const facebookUrl = site.order.facebookUrl;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Oakshade Acres',
  description,
  url: canonical,
  image: ogImageUrl,
  telephone: phone,
  email,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Dayton',
    addressRegion: 'TX',
    addressCountry: 'US',
  },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: 'Liberty County, Texas',
  },
  sameAs: [facebookUrl].filter(Boolean),
};
---
<!DOCTYPE html>
<html lang="en" class="no-js">
  <head>
    <script is:inline>
      document.documentElement.classList.remove('no-js');
      document.documentElement.classList.add('js');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Oakshade Acres" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Oakshade Acres — Specialty Poultry, English Orpingtons" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400..600;1,9..144,400..600&family=Inter+Tight:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Lora:ital,wght@1,400&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />

    <script>
      (function scrollReveal() {
        const targets = document.querySelectorAll<HTMLElement>('.reveal, .stagger');
        if (!('IntersectionObserver' in window) || targets.length === 0) {
          targets.forEach((el) => el.classList.add('in-view'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.08 }
        );
        targets.forEach((el) => io.observe(el));
      })();
    </script>

    <script>
      (function wrapAmpersands() {
        const run = () => {
          const heads = document.querySelectorAll(
            'h1, h2, h3, h4, h5, h6, .schedule-cell-breed, .test-text, .footer-statement, .nav-brand, .order-num'
          );
          heads.forEach((h) => {
            const walker = document.createTreeWalker(h, NodeFilter.SHOW_TEXT);
            const nodes: Text[] = [];
            let n: Node | null;
            while ((n = walker.nextNode())) {
              const t = n as Text;
              if (
                t.nodeValue &&
                t.nodeValue.includes('&') &&
                !(t.parentElement && t.parentElement.classList.contains('amp'))
              ) {
                nodes.push(t);
              }
            }
            nodes.forEach((node) => {
              const parts = (node.nodeValue || '').split(/(&)/);
              const frag = document.createDocumentFragment();
              parts.forEach((p) => {
                if (p === '&') {
                  const s = document.createElement('span');
                  s.className = 'amp';
                  s.textContent = '&';
                  frag.appendChild(s);
                } else if (p) {
                  frag.appendChild(document.createTextNode(p));
                }
              });
              node.parentNode?.replaceChild(frag, node);
            });
          });
        };
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', run);
        } else {
          run();
        }
      })();
    </script>
  </body>
</html>
