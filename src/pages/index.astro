---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Breeds from '../components/Breeds.astro';
import Schedule from '../components/Schedule.astro';
import Order from '../components/Order.astro';
import ContactSection from '../components/ContactSection.astro';
import PickupShipping from '../components/PickupShipping.astro';
import CareGuide from '../components/CareGuide.astro';
import FAQ from '../components/FAQ.astro';
import Testimonials from '../components/Testimonials.astro';
import SiteFooter from '../components/SiteFooter.astro';
import site from '../content/site.json';

const breedEntries = await getCollection('breeds');
const breeds = breedEntries
  .map((e) => ({ id: e.id, ...e.data }))
  .sort((a, b) => a.order - b.order);

const scheduleBreeds = breeds.map((b) => ({
  name: b.name,
  spring: b.spring,
  fall: b.fall,
}));

const breedOptions: string[] = [];
breeds.forEach((b) => {
  if (b.varieties.length) {
    b.varieties.forEach((v) => breedOptions.push(`${b.name} – ${v}`));
  } else {
    breedOptions.push(b.name);
  }
});
breedOptions.push('Multiple Breeds');
---
<Layout>
  <Nav logo={site.nav.logo} links={site.nav.links} cta={site.nav.cta} />
  <Hero
    logoImage={site.hero.logoImage}
    title={site.hero.title}
    tagline={site.hero.tagline}
    badges={site.hero.badges}
    ctas={site.hero.ctas}
  />
  <About
    label={site.about.label}
    title={site.about.title}
    paragraphs={site.about.paragraphs}
    image={site.about.image}
  />
  <Breeds
    label={site.breedsSection.label}
    title={site.breedsSection.title}
    breeds={breeds}
  />
  <Schedule
    label={site.schedule.label}
    title={site.schedule.title}
    sub={site.schedule.sub}
    springLabel={site.schedule.springLabel}
    fallLabel={site.schedule.fallLabel}
    footerNote={site.schedule.footerNote}
    breeds={scheduleBreeds}
  />
  <Order
    label={site.order.label}
    title={site.order.title}
    intro={site.order.intro}
    steps={site.order.steps}
    facebookUrl={site.order.facebookUrl}
    ctaLabel={site.order.ctaLabel}
    ctaNote={site.order.ctaNote}
  />
  <ContactSection
    label={site.contact.label}
    title={site.contact.title}
    intro={site.contact.intro}
    infoRows={site.contact.infoRows}
    email={site.contact.email}
    endpoint={site.contact.endpoint}
    breedOptions={breedOptions}
  />
  <PickupShipping
    label={site.pickupShippingSection.label}
    title={site.pickupShippingSection.title}
    cards={site.pickupShipping}
  />
  <CareGuide
    label={site.careGuideSection.label}
    title={site.careGuideSection.title}
    sub={site.careGuideSection.sub}
    items={site.careGuide}
  />
  <FAQ
    label={site.faqSection.label}
    title={site.faqSection.title}
    items={site.faqs}
  />
  <Testimonials
    label={site.testimonialsSection.label}
    title={site.testimonialsSection.title}
    items={site.testimonials}
  />
  <SiteFooter
    logoImage={site.footer.logoImage}
    brandName={site.footer.brandName}
    brandText={site.footer.brandText}
    getInTouch={site.footer.getInTouch}
    quickLinks={site.footer.quickLinks}
    copyright={site.footer.copyright}
  />
</Layout>
