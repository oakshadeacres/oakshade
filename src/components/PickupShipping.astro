---
interface Card { icon: string; title: string; text: string }
interface Props {
  label: string;
  title: string;
  cards: Card[];
}
const { label, title, cards } = Astro.props;
---
<section class="pickup">
  <div class="pickup-inner">
    <div class="sec-head reveal">
      <span class="eyebrow">{label}</span>
      <h2>{title}</h2>
    </div>
    <div class="pickup-grid stagger">
      {cards.map((c) => (
        <div class="pickup-card">
          <div class="ix">{c.icon}</div>
          <h3>{c.title}</h3>
          <p>{c.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
