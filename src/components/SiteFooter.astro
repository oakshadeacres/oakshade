---
interface LinkItem { label: string; href: string }
interface Props {
  logoImage: string;
  brandName: string;
  brandText: string;
  getInTouch: { title: string; items: LinkItem[]; note?: string };
  quickLinks: { title: string; items: LinkItem[] };
  copyright: string;
}
const { logoImage, brandName, brandText, getInTouch, quickLinks, copyright } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const logoSrc = logoImage.startsWith('http') ? logoImage : `${base}${logoImage}`;
---
<footer id="contact" class="site-footer">
  <div class="footer-inner">
    <p class="footer-statement">
      Raising quality birds <em>with care</em> and integrity.
    </p>

    <div class="footer-grid">
      <div class="footer-brand">
        <img src={logoSrc} alt={brandName} />
        <h3>{brandName}</h3>
        <p>{brandText}</p>
      </div>

      <div class="footer-col">
        <h4>{getInTouch.title}</h4>
        {getInTouch.items.map((item) => (
          <a href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined}>{item.label}</a>
        ))}
        {getInTouch.note && (
          <p class="note" set:html={getInTouch.note.replace(/\n/g, '<br/>')}></p>
        )}
      </div>

      <div class="footer-col">
        <h4>{quickLinks.title}</h4>
        {quickLinks.items.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </div>
    </div>

    <div class="footer-bar">{copyright}</div>
  </div>
</footer>
