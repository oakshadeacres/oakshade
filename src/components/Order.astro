---
interface Step { title: string; text: string }
interface Props {
  label: string;
  title: string;
  intro: string;
  steps: Step[];
  facebookUrl: string;
  ctaLabel: string;
  ctaNote: string;
}
const { label, title, intro, steps, facebookUrl, ctaLabel, ctaNote } = Astro.props;
---
<section id="order" class="section-full order-bg">
  <div class="section-inner">
    <p class="section-label reveal" style="color: var(--gold-light)">{label}</p>
    <h2 class="section-title reveal" style="color: var(--cream)">{title}</h2>
    <div class="divider reveal"></div>
    <p class="reveal" style="color: oklch(80% 0.02 80); max-width: 540px; margin-bottom: 8px">{intro}</p>
    <div class="order-steps stagger">
      {steps.map((s, i) => (
        <div class="order-step">
          <div class="order-num">{i + 1}</div>
          <h3>{s.title}</h3>
          <p>{s.text}</p>
        </div>
      ))}
    </div>
    <div class="order-cta reveal">
      <a class="btn-fb" href={facebookUrl} target="_blank" rel="noopener">
        <svg class="fb-icon" viewBox="0 0 24 24"><path fill="white" d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        {ctaLabel}
      </a>
      <p style="color: oklch(65% 0.02 70); font-size: 0.82rem; margin-top: 12px">{ctaNote}</p>
    </div>
  </div>
</section>
