---
interface Props {
  label: string;
  title: string;
  paragraphs: string[];
  image?: string;
}
const { label, title, paragraphs, image } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const imgSrc = image ? (image.startsWith('http') ? image : `${base}${image}`) : '';
---
<section id="about" class="section">
  <div class="about-grid">
    {imgSrc ? (
      <div class="about-img reveal-left">
        <img src={imgSrc} alt={`${title} — Oakshade Acres`} />
      </div>
    ) : (
      <div class="about-img-placeholder reveal-left">
        <svg width="40" height="40" viewBox="0 0 40 40" fill="none">
          <circle cx="20" cy="20" r="18" stroke="#C4963E" stroke-width="2"/>
          <path d="M12 28c2-6 14-6 16 0" stroke="#C4963E" stroke-width="2" stroke-linecap="round"/>
          <circle cx="20" cy="16" r="5" stroke="#C4963E" stroke-width="2"/>
        </svg>
        farm / family photo
      </div>
    )}
    <div class="about-text reveal-right">
      <p class="section-label">{label}</p>
      <h2 class="section-title">{title}</h2>
      <div class="divider"></div>
      {paragraphs.map((p) => <p>{p}</p>)}
    </div>
  </div>
</section>
