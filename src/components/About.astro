---
interface Props {
  label: string;
  title: string;
  paragraphs: string[];
  image?: string;
}
const { label, title, paragraphs } = Astro.props;
---
<section id="about" class="about">
  <div class="about-grid">
    <div class="about-side reveal">
      <span class="eyebrow">{label}</span>
      <h2>{title}</h2>
      <div class="meta">
        <span>Dayton, Texas · Liberty County</span>
        <span>English Orpingtons · Polish · Bantam Cochins · Bantam Easter Eggers</span>
      </div>
    </div>
    <div class="about-text reveal">
      {paragraphs.map((p) => <p>{p}</p>)}
    </div>
  </div>
</section>
