---
import Accordion from './Accordion.astro';

interface Item { q: string; a: string }
interface Props {
  label: string;
  title: string;
  items: Item[];
}
const { label, title, items } = Astro.props;
---
<section id="faq" class="faq">
  <div class="faq-inner">
    <div class="sec-head">
      <span class="eyebrow">{label}</span>
      <h2>{title}</h2>
    </div>
    <Accordion items={items} />
  </div>
</section>
