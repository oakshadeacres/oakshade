---
interface Breed { name: string; spring: string[]; fall: string[] }
interface Props {
  label: string;
  title: string;
  sub: string;
  springLabel: string;
  fallLabel: string;
  footerNote: string;
  breeds: Breed[];
}
const { label, title, sub, springLabel, fallLabel, footerNote, breeds } = Astro.props;
---
<section id="schedule" class="schedule">
  <div class="schedule-inner">
    <div class="sec-head reveal">
      <span class="eyebrow">{label}</span>
      <h2>{title}</h2>
      <p class="sub">{sub}</p>
    </div>

    <div class="schedule-table stagger">
      <div class="schedule-row head" role="row">
        <div>Breed</div>
        <div class="season-spring">{springLabel}</div>
        <div class="season-fall">{fallLabel}</div>
      </div>
      {breeds.map((b) => (
        <div class="schedule-row">
          <div class="schedule-cell schedule-cell-breed">{b.name}</div>
          <div class="schedule-cell schedule-cell-season">
            <div class="schedule-season-tag spring">{springLabel}</div>
            {b.spring.length === 0 ? (
              <span class="schedule-empty">Not available this season</span>
            ) : (
              <ul class="schedule-list">
                {b.spring.map((v) => (
                  <li><span class="schedule-marker spring"></span>{v}</li>
                ))}
              </ul>
            )}
          </div>
          <div class="schedule-cell schedule-cell-season">
            <div class="schedule-season-tag fall">{fallLabel}</div>
            {b.fall.length === 0 ? (
              <span class="schedule-empty">Not available this season</span>
            ) : (
              <ul class="schedule-list">
                {b.fall.map((v) => (
                  <li><span class="schedule-marker fall"></span>{v}</li>
                ))}
              </ul>
            )}
          </div>
        </div>
      ))}
    </div>
    <p class="schedule-footnote">{footerNote}</p>
  </div>
</section>
