---
interface Item { name: string; text: string; stars: number }
interface Props {
  label: string;
  title: string;
  items: Item[];
}
const { label, title, items } = Astro.props;
---
<section class="section-full testimonials-bg">
  <div class="section-inner" style="padding: 64px 24px">
    <p class="section-label reveal">{label}</p>
    <h2 class="section-title reveal">{title}</h2>
    <div class="divider reveal"></div>
    <div class="test-grid stagger">
      {items.map((t) => (
        <div class="test-card">
          <div class="test-quote">"</div>
          <p class="test-text">{t.text}</p>
          <div class="test-stars">{'★'.repeat(t.stars)}</div>
          <div class="test-name">{t.name}</div>
        </div>
      ))}
    </div>
  </div>
</section>
