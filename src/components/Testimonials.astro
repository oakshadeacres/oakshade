---
interface Item { name: string; text: string; stars: number }
interface Props {
  label: string;
  title: string;
  items: Item[];
}
const { label, title, items } = Astro.props;
---
<section class="testimonials">
  <div class="testimonials-inner">
    <div class="sec-head reveal">
      <span class="eyebrow">{label}</span>
      <h2>{title}</h2>
    </div>
    <div class="test-grid stagger">
      {items.map((t) => (
        <div class="test-item">
          <div class="test-stars" aria-label={`${t.stars} out of 5 stars`}>{'★'.repeat(t.stars)}</div>
          <p class="test-text">“{t.text}”</p>
          <div class="test-name">— {t.name}</div>
        </div>
      ))}
    </div>
  </div>
</section>
