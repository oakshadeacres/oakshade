---
import Accordion from './Accordion.astro';

interface Item { q: string; a: string }
interface Props {
  label: string;
  title: string;
  sub: string;
  items: Item[];
}
const { label, title, sub, items } = Astro.props;
---
<section id="care" class="care">
  <div class="care-inner">
    <div class="sec-head reveal">
      <span class="eyebrow">{label}</span>
      <h2>{title}</h2>
      <p class="sub">{sub}</p>
    </div>
    <div class="reveal">
      <Accordion items={items} />
    </div>
  </div>
</section>
