---
import ContactForm from './ContactForm.astro';

interface InfoRow { icon: string; text: string }
interface Props {
  label: string;
  title: string;
  intro: string;
  infoRows: InfoRow[];
  email: string;
  endpoint?: string;
  breedOptions: string[];
}
const { label, title, intro, infoRows, email, endpoint = '', breedOptions } = Astro.props;
---
<section id="contact-form" class="contact-sec">
  <div class="contact-grid">
    <div class="contact-side reveal">
      <div class="sec-head">
        <span class="eyebrow">{label}</span>
        <h2>{title}</h2>
        <p class="sub">{intro}</p>
      </div>
      <div class="contact-info">
        {infoRows.map((row) => (
          <div class="contact-info-row">
            <span class="icon">{row.icon}</span>
            <span class="text">{row.text}</span>
          </div>
        ))}
      </div>
    </div>
    <ContactForm email={email} endpoint={endpoint} breedOptions={breedOptions} />
  </div>
</section>
