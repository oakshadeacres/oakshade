---
interface Trait { label: string; val: string }
interface BreedImage { url: string; variety?: string }
interface Breed {
  id: string;
  name: string;
  specialty: boolean;
  description: string;
  traits: Trait[];
  varieties: { name: string; price?: string }[];
  images: BreedImage[];
}
interface Props {
  label: string;
  title: string;
  breeds: Breed[];
}
const { label, title, breeds } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const breedsData = breeds.map((b) => ({
  ...b,
  images: b.images.map((img) => ({
    url: img.url.startsWith('http') ? img.url : `${base}${img.url}`,
    variety: img.variety,
  })),
}));

const firstBreed = breedsData[0];
const firstImage = firstBreed?.images[0];
const initialSrc = firstImage?.url ?? '';
const initialAlt = firstImage
  ? (firstImage.variety ? `${firstImage.variety} ${firstBreed.name}` : firstBreed.name)
  : '';
const initialFallbackName = firstBreed && !firstImage
  ? `${firstBreed.varieties[0]?.name ?? ''} ${firstBreed.name}`.trim()
  : '';
---
<section id="breeds" class="breeds">
  <div class="breeds-inner">
    <div class="sec-head reveal">
      <span class="eyebrow">{label}</span>
      <h2>{title}</h2>
    </div>

    <div class="breed-tabs reveal" data-breed-tabs role="tablist">
      {breedsData.map((b, i) => (
        <button
          class={`breed-tab${i === 0 ? ' active' : ''}`}
          data-breed-tab={b.id}
          type="button"
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
        >
          {b.name}{b.specialty && <span class="star">★</span>}
        </button>
      ))}
    </div>

    <div class="breed-card reveal" data-breed-card>
      <div class="breed-gallery" data-breed-gallery>
        <div class="breed-img" data-breed-img>
          <img data-breed-img-el src={initialSrc} alt={initialAlt} style={firstImage ? '' : 'display:none'} />
          <div data-breed-img-label-fallback class="breed-img-fallback" style={`display:${firstImage ? 'none' : 'flex'}`}>
            <svg width="44" height="44" viewBox="0 0 36 36" fill="none" stroke="currentColor" stroke-width="1.4">
              <ellipse cx="18" cy="22" rx="12" ry="9"/>
              <circle cx="18" cy="11" r="6"/>
              <path d="M24 8l4-2M12 8l-4-2" stroke-linecap="round"/>
            </svg>
            <span data-breed-img-name>{initialFallbackName}</span>
          </div>
          <div class="breed-img-counter" data-breed-img-counter></div>
        </div>
        <button class="breed-arrow prev" data-breed-prev aria-label="Previous image" type="button">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 2L4 7l5 5"/>
          </svg>
        </button>
        <button class="breed-arrow next" data-breed-next aria-label="Next image" type="button">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 2l5 5-5 5"/>
          </svg>
        </button>
        <div class="breed-dots" data-breed-dots></div>
      </div>

      <div class="breed-varieties">
        <h4>Varieties We Carry</h4>
        <div class="variety-pills" data-breed-varieties></div>
      </div>

      <div class="breed-info">
        <span class="breed-specialty" data-breed-specialty style="display:none">★ Our Specialty</span>
        <h3 data-breed-name></h3>
        <p class="breed-desc" data-breed-desc></p>
        <div class="breed-traits" data-breed-traits></div>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ breedsData }}>
  (function () {
    const tabs = document.querySelectorAll('[data-breed-tab]');
    const specialtyEl = document.querySelector('[data-breed-specialty]');
    const nameEl = document.querySelector('[data-breed-name]');
    const descEl = document.querySelector('[data-breed-desc]');
    const traitsEl = document.querySelector('[data-breed-traits]');
    const varietiesEl = document.querySelector('[data-breed-varieties]');
    const imgEl = document.querySelector('[data-breed-img-el]');
    const imgFallback = document.querySelector('[data-breed-img-label-fallback]');
    const imgNameEl = document.querySelector('[data-breed-img-name]');
    const counterEl = document.querySelector('[data-breed-img-counter]');
    const dotsEl = document.querySelector('[data-breed-dots]');
    const prevBtn = document.querySelector('[data-breed-prev]');
    const nextBtn = document.querySelector('[data-breed-next]');

    let activeId = breedsData[0]?.id;
    let slide = 0;

    function current() {
      return breedsData.find((b) => b.id === activeId) || breedsData[0];
    }

    function renderGallery() {
      const b = current();
      const hasImage = b.images.length > 0;
      const total = hasImage ? b.images.length : (b.varieties.length || 1);
      if (slide >= total) slide = 0;

      if (hasImage) {
        const img = b.images[slide];
        imgEl.src = img.url;
        imgEl.alt = img.variety ? `${img.variety} ${b.name}` : b.name;
        imgEl.style.display = 'block';
        imgFallback.style.display = 'none';
      } else {
        imgEl.style.display = 'none';
        imgFallback.style.display = 'flex';
        const label = b.varieties.length ? (b.varieties[slide]?.name ?? b.name) : b.name;
        imgNameEl.textContent = `${label} ${b.name}`.trim();
      }
      counterEl.textContent = total > 1 ? `${slide + 1} / ${total}` : '';
      counterEl.style.display = total > 1 ? 'block' : 'none';
      prevBtn.style.display = total > 1 ? 'flex' : 'none';
      nextBtn.style.display = total > 1 ? 'flex' : 'none';

      dotsEl.innerHTML = '';
      if (total > 1) {
        for (let i = 0; i < total; i++) {
          const d = document.createElement('button');
          d.className = `breed-dot${i === slide ? ' active' : ''}`;
          d.type = 'button';
          d.setAttribute('aria-label', `Go to slide ${i + 1}`);
          d.addEventListener('click', () => { slide = i; renderGallery(); renderVarietyPills(); });
          dotsEl.appendChild(d);
        }
      }
      renderPrice();
    }

    function renderPrice() {
      const traitEl = document.querySelector('[data-breed-price-trait]');
      const amountEl = document.querySelector('[data-breed-price-amount]');
      if (!traitEl || !amountEl) return;
      const b = current();
      const hasImage = b.images.length > 0;
      const currentName = hasImage ? (b.images[slide]?.variety || null) : (b.varieties[slide]?.name || null);
      const match = currentName ? b.varieties.find((v) => v.name === currentName) : null;
      if (match && match.price) {
        amountEl.textContent = match.price;
        traitEl.style.display = '';
      } else {
        traitEl.style.display = 'none';
      }
    }

    function renderVarietyPills() {
      const b = current();
      const hasImage = b.images.length > 0;
      const currentVariety = hasImage ? (b.images[slide]?.variety || null) : (b.varieties[slide]?.name || null);
      varietiesEl.innerHTML = '';
      b.varieties.forEach((v, i) => {
        const pill = document.createElement('button');
        pill.type = 'button';
        pill.textContent = v.name;

        if (hasImage) {
          const firstMatch = b.images.findIndex((im) => im.variety === v.name);
          const isEmpty = firstMatch === -1;
          const isActive = currentVariety === v.name;
          pill.className = `variety-pill${isActive ? ' active' : ''}${isEmpty ? ' variety-pill-empty' : ''}`;
          if (isEmpty) {
            pill.setAttribute('aria-disabled', 'true');
          } else {
            pill.addEventListener('click', () => { slide = firstMatch; renderGallery(); renderVarietyPills(); });
          }
        } else {
          pill.className = `variety-pill${i === slide ? ' active' : ''}`;
          pill.addEventListener('click', () => { slide = i; renderGallery(); renderVarietyPills(); });
        }

        varietiesEl.appendChild(pill);
      });
    }

    function renderAll() {
      const b = current();
      specialtyEl.style.display = b.specialty ? 'inline-flex' : 'none';
      nameEl.textContent = b.name;
      descEl.textContent = b.description;
      traitsEl.innerHTML = '';
      b.traits.forEach((t) => {
        const trait = document.createElement('div');
        trait.className = 'trait';
        const label = document.createElement('div');
        label.className = 'trait-label';
        label.textContent = t.label;
        const val = document.createElement('div');
        val.className = 'trait-val';
        val.textContent = t.val;
        trait.appendChild(label);
        trait.appendChild(val);
        traitsEl.appendChild(trait);
      });
      // Price-per-chick tile — styled like the other attributes, updated per variety.
      const priceTrait = document.createElement('div');
      priceTrait.className = 'trait';
      priceTrait.setAttribute('data-breed-price-trait', '');
      priceTrait.style.display = 'none';
      const priceLabel = document.createElement('div');
      priceLabel.className = 'trait-label';
      priceLabel.textContent = 'Price per chick';
      const priceVal = document.createElement('div');
      priceVal.className = 'trait-val';
      priceVal.setAttribute('data-breed-price-amount', '');
      priceTrait.appendChild(priceLabel);
      priceTrait.appendChild(priceVal);
      traitsEl.appendChild(priceTrait);
      renderGallery();
      renderVarietyPills();
    }

    tabs.forEach((t) => {
      t.addEventListener('click', () => {
        tabs.forEach((x) => { x.classList.remove('active'); x.setAttribute('aria-selected', 'false'); });
        t.classList.add('active');
        t.setAttribute('aria-selected', 'true');
        activeId = t.getAttribute('data-breed-tab');
        slide = 0;
        renderAll();
      });
    });

    function slideCount(b) {
      return b.images.length || b.varieties.length || 1;
    }

    prevBtn.addEventListener('click', () => {
      const b = current();
      const total = slideCount(b);
      slide = (slide - 1 + total) % total;
      renderGallery();
      renderVarietyPills();
    });
    nextBtn.addEventListener('click', () => {
      const b = current();
      const total = slideCount(b);
      slide = (slide + 1) % total;
      renderGallery();
      renderVarietyPills();
    });

    const gallery = document.querySelector('[data-breed-gallery]');
    let startX = null;
    gallery.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; }, { passive: true });
    gallery.addEventListener('touchend', (e) => {
      if (startX === null) return;
      const dx = e.changedTouches[0].clientX - startX;
      if (dx > 40) prevBtn.click();
      else if (dx < -40) nextBtn.click();
      startX = null;
    });

    renderAll();
  })();
</script>
